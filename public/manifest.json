{
  "manifest_version": 3,
  "name": "Sunbeam Cookie Jar",
  "description": "A local-only developer tool for managing cookies on the current site.",
  "version": "0.1.0",
  "key": "",
  "action": {
    "default_title": "Sunbeam Cookie Jar",
    "default_popup": "popup.html"
  },
  "permissions": ["cookies", "storage", "activeTab"],
  "optional_host_permissions": ["http://*/*", "https://*/*"]
}
